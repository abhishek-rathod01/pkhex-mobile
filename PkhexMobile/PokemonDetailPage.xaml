<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.PokemonDetailPage"
             Title="Details">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Hero -->
            <Grid ColumnDefinitions="88,*" ColumnSpacing="16" Margin="0,4,0,0">
                <Border WidthRequest="88" HeightRequest="88" Stroke="Transparent" StrokeThickness="0"
                        BackgroundColor="{StaticResource SurfaceSunken}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid>
                        <Image Source="sprite_placeholder.svg" Aspect="AspectFit"
                               WidthRequest="44" HeightRequest="44"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Image x:Name="SpriteImage" Aspect="AspectFit"
                               WidthRequest="76" HeightRequest="76"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="TitleLabel" Style="{StaticResource HeroTitleStyle}" />
                        <Label x:Name="ShinyStarLabel" Text="&#9733;" Style="{StaticResource ShinyStarStyle}" IsVisible="False" />
                    </HorizontalStackLayout>
                    <Label x:Name="SubtitleLabel" Style="{StaticResource MutedStyle}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Legality result banner: read-only PKHeX.Core LegalityAnalysis snapshot, recomputed on
                 load and after a successful save. No auto-fix - this only reports. -->
            <Border x:Name="LegalityBanner">
                <VerticalStackLayout Spacing="8">
                    <Border x:Name="LegalityBadgeBorder">
                        <Label x:Name="LegalityBadgeLabel" />
                    </Border>
                    <Label x:Name="LegalityMessageLabel" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Legality warning banner (always visible - no auto-fix/legality engine, see README) -->
            <Border BackgroundColor="{StaticResource StatusWarnBg}" Stroke="Transparent" StrokeThickness="0" Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label x:Name="LegalityWarningLabel"
                       Text="⚠ Species, form, ability, nature, gender, and move edits are applied exactly as chosen. PKHeX.Core does not auto-fix legality, so the result may be flagged as illegal by other tools. This is expected."
                       Style="{StaticResource WarningBannerStyle}"
                       LineBreakMode="WordWrap" />
            </Border>

            <!-- Main -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Main" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="Nickname" Style="{StaticResource LabelCaptionStyle}" />
                    <Entry x:Name="NicknameEntry" />

                    <Label Text="Level" Style="{StaticResource LabelCaptionStyle}" />
                    <Entry x:Name="LevelEntry" Keyboard="Numeric" />

                    <Label Text="Species" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="SpeciesPicker" Title="Select species" />

                    <!-- Form: only enabled Gen4+ (independently stored - see PROGRESS.md) and when
                         the current species actually has more than one form. Gen1-3's Form setter
                         only ever does anything for Unown (via IV/PID randomization side effects) -
                         deliberately not wired up here (too surprising to expose as a plain picker),
                         so it's disabled there too. Always shown (not hidden) so the current value is
                         still visible, matching the Gen1/2 IV field disabling precedent. -->
                    <Label x:Name="FormCaptionLabel" Text="Form" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="FormPicker" Title="Select form" />

                    <!-- Held item: editable Gen2+ via pk.ApplyHeldItem. Gen1 is a hard no-op
                         (PK1.cs:157 `HeldItem { get => 0; set { } }` - RBY has no held items and
                         that byte is the catch rate), so the Picker is disabled there with the
                         reason inline, same precedent as the Gen1/2 IV fields and the Ability/
                         Nature pickers. The icon keeps its own row beside the Picker rather than
                         inside it: MAUI renders Picker dropdown rows as plain strings and cannot
                         host an Image. -->
                    <Label x:Name="ItemCaptionLabel" Text="Held item" Style="{StaticResource LabelCaptionStyle}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Border x:Name="ItemIconBorder" WidthRequest="28" HeightRequest="28"
                                Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"
                                BackgroundColor="{StaticResource SurfaceSunken}" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Image x:Name="ItemSpriteImage" Aspect="AspectFit" WidthRequest="20" HeightRequest="20" />
                        </Border>
                        <Picker Grid.Column="1" x:Name="ItemPicker" Title="Select held item" />
                    </Grid>

                    <!-- Ball: editable Gen3+ via pk.Ball (real storage, incl. Gen4's composite
                         BallDPPt/BallHGSS handled internally by the sealed override). Gen1/2 share
                         GBPKM's hard no-op (GBPKM.cs:135, get => 0; set { } - RBY/GSC never stored
                         which ball caught the Pokemon), so disabled there with the reason inline. -->
                    <Label x:Name="BallCaptionLabel" Text="Ball" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="BallPicker" Title="Select ball" />

                    <!-- Friendship: editable Gen2+ via pk.CurrentFriendship. Gen1 is a hard no-op
                         (PK1.cs:155, get => 0; set { } - RBY has no friendship stat at all). Gen3/4/5
                         genuinely persist the value (verified against PKM sources) - they just alias
                         the same storage as OriginalTrainerFriendship, which is a naming/semantic
                         quirk (see PROGRESS.md), not a no-op, so no extra gating is needed for them. -->
                    <Label x:Name="FriendshipCaptionLabel" Text="Friendship" Style="{StaticResource LabelCaptionStyle}" />
                    <Entry x:Name="FriendshipEntry" Keyboard="Numeric" />

                    <!-- Gender: editable Gen4+ via pk.Gender (real independent storage - PK4.cs
                         Data[0x40]). Gen1/2 derive it from IV_ATK vs. the species' gender-ratio
                         threshold (GBPKM.cs:106-119, setter is a hard no-op); Gen3 derives it from
                         PID vs. the same threshold (G3PKM.cs:37, also a hard no-op) - both disabled
                         here with the reason inline, same precedent as Ball/Friendship/Ability/
                         Nature above. Unconstrained by the species' actual gender ratio (matches
                         this app's stance on Nature/Ability/Form: applied exactly as chosen, the
                         read-only legality badge is what reports a mismatch, not a picker guard). -->
                    <Label x:Name="GenderCaptionLabel" Text="Gender" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="GenderPicker" Title="Select gender" />

                    <!-- Pokerus: editable Gen2+ via pk.PokerusStrain/PokerusDays (one packed byte -
                         upper nibble strain, lower nibble days - identical bit layout confirmed
                         across PK2/PK3/PK9 in verify/PokerusEdit). Gen1 is a hard no-op (PK1.cs:
                         149-150, get => 0; set { } - RBY has no Pokerus mechanic at all), disabled
                         there with the reason inline, same precedent as Ball/Friendship above.
                         Applied as-is everywhere else, including PA8/PK9/PA9 where the real games
                         never naturally produce a nonzero value (Editing/Pokerus.cs's own
                         IsObtainable) - same "edits applied exactly as chosen, legality reported
                         not enforced" stance as Nature/Gender/Ability, not a second no-op gate. -->
                    <Label x:Name="PokerusCaptionLabel" Text="Pokerus" Style="{StaticResource LabelCaptionStyle}" />
                    <Grid ColumnDefinitions="Auto,Auto,12,Auto,Auto" ColumnSpacing="6">
                        <Label Grid.Column="0" Text="Strain" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="PokerusStrainEntry" Keyboard="Numeric" WidthRequest="52" />
                        <Label Grid.Column="3" Text="Days" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <Entry Grid.Column="4" x:Name="PokerusDaysEntry" Keyboard="Numeric" WidthRequest="52" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Markings: the 6 small shapes shown under a Pokemon in the in-game box/party list,
                 commonly used for personal sorting. Editable Gen3+ (IAppliedMarkings<bool>/
                 <MarkingColor> - no marking concept exists in Gen1/2 at all, not merely a no-op).
                 Gen3 has only 4 (Circle/Triangle/Square/Heart - Star/Diamond hidden); Gen4-6 have
                 all 6 as on/off; Gen7+ have all 6 as a 3-state None/Blue/Pink cycle. One tap
                 handler per chip cycles through whatever states this generation's format
                 actually supports - see PokemonDetailPage.xaml.cs OnMarkingChipTapped. -->
            <Border x:Name="MarkingsCard" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Markings" Style="{StaticResource SectionTitleStyle}" />
                    <Label x:Name="MarkingsCaptionLabel" Style="{StaticResource MutedStyle}" />
                    <HorizontalStackLayout Spacing="10">
                        <Border x:Name="MarkingCircleChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <Label x:Name="MarkingCircleGlyph" Text="&#9679;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="0" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="MarkingTriangleChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <Label x:Name="MarkingTriangleGlyph" Text="&#9650;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="1" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="MarkingSquareChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <Label x:Name="MarkingSquareGlyph" Text="&#9632;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="2" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="MarkingHeartChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <!-- U+2665 has a colored-emoji presentation on Android that ignores this
                                 Label's TextColor and renders as a fixed red heart regardless of
                                 marking state - confirmed on-device (a real bug, not a data issue;
                                 the underlying MarkingColor was correctly None the whole time).
                                 U+FE0E (text presentation selector) forces the plain monochrome
                                 glyph, matching how Circle/Triangle/Square/Star/Diamond already
                                 render (none of those codepoints have an emoji presentation, so
                                 they were never affected). -->
                            <Label x:Name="MarkingHeartGlyph" Text="&#9829;&#65038;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="3" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="MarkingStarChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <Label x:Name="MarkingStarGlyph" Text="&#9733;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="4" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="MarkingDiamondChip" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="{StaticResource RadiusPill}" /></Border.StrokeShape>
                            <Label x:Name="MarkingDiamondGlyph" Text="&#9670;" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMarkingChipTapped" CommandParameter="5" />
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Moves -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Moves" Style="{StaticResource SectionTitleStyle}" />

                    <!-- Each row is the design bundle's MoveRow (ui_kits/pkhexmobile/DetailScreen.jsx):
                         a solid TypeBadge leading the move, at a fixed width so the four rows align.
                         The bundle's MoveRow is read-only text; here the move itself stays the working
                         editable Picker (same precedent as the rest of this form - apply the visual
                         language, don't replace a working editor with an inert display). The chip is a
                         sibling of the Picker rather than inside it because MAUI renders Picker dropdown
                         rows as plain strings and cannot host a styled view; the type is carried into the
                         dropdown as a "(Type)" suffix on the item text instead - see PopulateMovePickers. -->
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border x:Name="Move1TypeChip" Style="{StaticResource TypeChipBorderStyle}">
                                <Label x:Name="Move1TypeLabel" Style="{StaticResource TypeChipLabelStyle}" />
                            </Border>
                            <Picker Grid.Column="1" x:Name="Move1Picker" Title="Move 1" />
                            <Border Grid.Column="2" x:Name="Move1LegalityDot" Style="{StaticResource MoveLegalityDotPassStyle}">
                                <Label x:Name="Move1LegalityGlyph" Style="{StaticResource MoveLegalityDotLabelPassStyle}" />
                            </Border>
                        </Grid>
                        <!-- PP / PP Ups: pk.MoveN_PP / pk.MoveN_PPUps, uniform abstract members with no
                             per-generation split (unlike the rest of this page's editable fields). The
                             app previously only ever called SetMoves (which auto-maxes PP on a move
                             change); this exposes manual control over both independently. -->
                        <Grid ColumnDefinitions="Auto,Auto,12,Auto,Auto" ColumnSpacing="6" Margin="50,0,0,0">
                            <Label Grid.Column="0" Text="PP" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="1" x:Name="Move1PpEntry" Keyboard="Numeric" WidthRequest="52" />
                            <Label Grid.Column="3" Text="PP Ups" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="4" x:Name="Move1PpUpsEntry" Keyboard="Numeric" WidthRequest="52" />
                        </Grid>
                        <Label x:Name="Move1LegalityCaption" Style="{StaticResource MoveLegalityCaptionStyle}" IsVisible="False" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border x:Name="Move2TypeChip" Style="{StaticResource TypeChipBorderStyle}">
                                <Label x:Name="Move2TypeLabel" Style="{StaticResource TypeChipLabelStyle}" />
                            </Border>
                            <Picker Grid.Column="1" x:Name="Move2Picker" Title="Move 2" />
                            <Border Grid.Column="2" x:Name="Move2LegalityDot" Style="{StaticResource MoveLegalityDotPassStyle}">
                                <Label x:Name="Move2LegalityGlyph" Style="{StaticResource MoveLegalityDotLabelPassStyle}" />
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,12,Auto,Auto" ColumnSpacing="6" Margin="50,0,0,0">
                            <Label Grid.Column="0" Text="PP" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="1" x:Name="Move2PpEntry" Keyboard="Numeric" WidthRequest="52" />
                            <Label Grid.Column="3" Text="PP Ups" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="4" x:Name="Move2PpUpsEntry" Keyboard="Numeric" WidthRequest="52" />
                        </Grid>
                        <Label x:Name="Move2LegalityCaption" Style="{StaticResource MoveLegalityCaptionStyle}" IsVisible="False" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border x:Name="Move3TypeChip" Style="{StaticResource TypeChipBorderStyle}">
                                <Label x:Name="Move3TypeLabel" Style="{StaticResource TypeChipLabelStyle}" />
                            </Border>
                            <Picker Grid.Column="1" x:Name="Move3Picker" Title="Move 3" />
                            <Border Grid.Column="2" x:Name="Move3LegalityDot" Style="{StaticResource MoveLegalityDotPassStyle}">
                                <Label x:Name="Move3LegalityGlyph" Style="{StaticResource MoveLegalityDotLabelPassStyle}" />
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,12,Auto,Auto" ColumnSpacing="6" Margin="50,0,0,0">
                            <Label Grid.Column="0" Text="PP" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="1" x:Name="Move3PpEntry" Keyboard="Numeric" WidthRequest="52" />
                            <Label Grid.Column="3" Text="PP Ups" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="4" x:Name="Move3PpUpsEntry" Keyboard="Numeric" WidthRequest="52" />
                        </Grid>
                        <Label x:Name="Move3LegalityCaption" Style="{StaticResource MoveLegalityCaptionStyle}" IsVisible="False" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border x:Name="Move4TypeChip" Style="{StaticResource TypeChipBorderStyle}">
                                <Label x:Name="Move4TypeLabel" Style="{StaticResource TypeChipLabelStyle}" />
                            </Border>
                            <Picker Grid.Column="1" x:Name="Move4Picker" Title="Move 4" />
                            <Border Grid.Column="2" x:Name="Move4LegalityDot" Style="{StaticResource MoveLegalityDotPassStyle}">
                                <Label x:Name="Move4LegalityGlyph" Style="{StaticResource MoveLegalityDotLabelPassStyle}" />
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,12,Auto,Auto" ColumnSpacing="6" Margin="50,0,0,0">
                            <Label Grid.Column="0" Text="PP" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="1" x:Name="Move4PpEntry" Keyboard="Numeric" WidthRequest="52" />
                            <Label Grid.Column="3" Text="PP Ups" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                            <Entry Grid.Column="4" x:Name="Move4PpUpsEntry" Keyboard="Numeric" WidthRequest="52" />
                        </Grid>
                        <Label x:Name="Move4LegalityCaption" Style="{StaticResource MoveLegalityCaptionStyle}" IsVisible="False" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Computed (read-only): battle stats calculated fresh from the currently-stored
                 IV/EV/level/nature/species (PKM.GetStats - does not require or mutate the party
                 stat block, so it works the same for a party mon and a box mon), current-games
                 type(s) from PersonalTable.SV (same source/tradeoff as the Pokedex feature - shows
                 today's type, e.g. Fairy for Clefairy, not necessarily this mon's origin-generation
                 type), and Hidden Power type (IV-derived, Gen3+ only - see PokemonDetailPage.cs). -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Computed" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="Type" Style="{StaticResource LabelCaptionStyle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Border x:Name="ComputedType1Chip" Style="{StaticResource TypeChipBorderStyle}">
                            <Label x:Name="ComputedType1Label" Style="{StaticResource TypeChipLabelStyle}" />
                        </Border>
                        <Border x:Name="ComputedType2Chip" Style="{StaticResource TypeChipBorderStyle}" IsVisible="False">
                            <Label x:Name="ComputedType2Label" Style="{StaticResource TypeChipLabelStyle}" />
                        </Border>
                    </HorizontalStackLayout>

                    <Label Text="Battle Stats" Style="{StaticResource LabelCaptionStyle}" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="HP" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedHpLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Atk" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedAtkLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="0">
                            <Label Text="Def" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedDefLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="0">
                            <Label Text="SpA" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedSpaLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="4" Spacing="0">
                            <Label Text="SpD" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedSpdLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="5" Spacing="0">
                            <Label Text="Spe" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
                            <Label x:Name="ComputedSpeLabel" Style="{StaticResource RowTitleStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label x:Name="HiddenPowerLabel" Style="{StaticResource MutedStyle}" Margin="0,6,0,0" />
                    <Label x:Name="CharacteristicLabel" Style="{StaticResource MutedStyle}" IsVisible="False" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Stats" Style="{StaticResource SectionTitleStyle}" />

                    <!-- Ability: only enabled Gen4+ (independently stored, real setter - see
                         PROGRESS.md). Gen1/2 has no Ability concept at all (sentinel -1); Gen3's
                         Ability is real and meaningful to *display* (derived from the ability slot)
                         but its direct-by-ID setter is a no-op - both stay disabled, but still show
                         the correct current value rather than a misleading one. -->
                    <Label x:Name="AbilityCaptionLabel" Text="Ability" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="AbilityPicker" Title="Select ability" />

                    <!-- Nature: only enabled Gen5+ (independently stored, real setter - see
                         PROGRESS.md). Gen3/4's Nature is real and meaningful to *display* (PID % 25)
                         but its setter is a no-op absent a PID-rerolling workaround this app
                         deliberately doesn't use (PKHeX.Core's own SetPIDNature also de-shinies the
                         mon as a side effect - too surprising for a plain picker). Gen1/2 has no
                         Nature concept at all (sentinel Hardy/0). -->
                    <Label x:Name="NatureCaptionLabel" Text="Nature" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="NaturePicker" Title="Select nature" />

                    <Label x:Name="IvRangeLabel" Text="IVs (0-31 each)" Style="{StaticResource LabelCaptionStyle}" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <Entry x:Name="IvHpEntry" Grid.Column="0" Keyboard="Numeric" Placeholder="HP" />
                        <Entry x:Name="IvAtkEntry" Grid.Column="1" Keyboard="Numeric" Placeholder="Atk" />
                        <Entry x:Name="IvDefEntry" Grid.Column="2" Keyboard="Numeric" Placeholder="Def" />
                        <Entry x:Name="IvSpaEntry" Grid.Column="3" Keyboard="Numeric" Placeholder="SpA" />
                        <Entry x:Name="IvSpdEntry" Grid.Column="4" Keyboard="Numeric" Placeholder="SpD" />
                        <Entry x:Name="IvSpeEntry" Grid.Column="5" Keyboard="Numeric" Placeholder="Spe" />
                    </Grid>

                    <Label x:Name="EvRangeLabel" Text="EVs (0-252 each)" Style="{StaticResource LabelCaptionStyle}" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <Entry x:Name="EvHpEntry" Grid.Column="0" Keyboard="Numeric" Placeholder="HP" />
                        <Entry x:Name="EvAtkEntry" Grid.Column="1" Keyboard="Numeric" Placeholder="Atk" />
                        <Entry x:Name="EvDefEntry" Grid.Column="2" Keyboard="Numeric" Placeholder="Def" />
                        <Entry x:Name="EvSpaEntry" Grid.Column="3" Keyboard="Numeric" Placeholder="SpA" />
                        <Entry x:Name="EvSpdEntry" Grid.Column="4" Keyboard="Numeric" Placeholder="SpD" />
                        <Entry x:Name="EvSpeEntry" Grid.Column="5" Keyboard="Numeric" Placeholder="Spe" />
                    </Grid>

                    <!-- Live EV budget readout. ADVISORY, not a constraint: Gen3+ games cap the
                         SUM of all six EVs at 510, but this app's stance is "edits are applied as
                         chosen, legality is reported not enforced" (see the warning banner and the
                         read-only legality badge above), so going over recolours this caption
                         rather than blocking the keystroke or the save. Hidden entirely on Gen1/2,
                         which have no 510 budget - PKHeX.Core's own GetMaximumEV returns a flat
                         EffortValues.Max12 for Format < 3. -->
                    <Label x:Name="EvTotalLabel" Style="{StaticResource MutedStyle}" IsVisible="False" />
                </VerticalStackLayout>
            </Border>

            <Button x:Name="TransferBtn"
                    Text="Import / Export"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Clicked="OnTransferClicked"
                    HorizontalOptions="Fill" />

            <Button x:Name="SaveChangesBtn"
                    Text="Save Changes"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="OnSaveChangesClicked"
                    HorizontalOptions="Fill"
                    IsEnabled="False" />

            <Label x:Name="SaveStatusLabel" Style="{StaticResource MutedStyle}" LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
