<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PkhexMobile">

    <!-- ================================================================
         PkhexMobile visual language — light theme only (the design
         handoff bundle documents a single light palette; no dark-mode
         tokens were provided, so no AppThemeBinding dark branch here).
         ================================================================ -->

    <!-- ===== Text roles (tokens/typography.css "role" custom properties) ===== -->
    <Style x:Key="ScreenTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGroteskBold" />
        <Setter Property="FontSize" Value="{StaticResource Text2xl}" />
        <Setter Property="LineHeight" Value="{StaticResource LhTight}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- PartyRow/DetailScreen primary name line: fw-bold 16-28px font-display -->
    <Style x:Key="RowTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGroteskBold" />
        <Setter Property="FontSize" Value="{StaticResource TextMd}" />
        <Setter Property="LineHeight" Value="{StaticResource LhTight}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="HeroTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGroteskBold" />
        <Setter Property="FontSize" Value="{StaticResource Text3xl}" />
        <Setter Property="LineHeight" Value="{StaticResource LhTight}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="ShinyStarStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeBold" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource ShinyFg}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGroteskSemiBold" />
        <Setter Property="FontSize" Value="{StaticResource TextMd}" />
        <Setter Property="LineHeight" Value="{StaticResource LhSnug}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="LineHeight" Value="{StaticResource LhNormal}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodySecondaryStyle" TargetType="Label" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="LabelCaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeSemiBold" />
        <Setter Property="FontSize" Value="{StaticResource TextXs}" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <Style x:Key="MutedStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiary}" />
    </Style>

    <!-- LegalityBadge (components/indicators/LegalityBadge.jsx): pass/fail pill + banner -->
    <Style x:Key="LegalityBadgePassStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusPassBg}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="999" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="LegalityBadgeFailStyle" TargetType="Border" BasedOn="{StaticResource LegalityBadgePassStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusFailBg}" />
    </Style>
    <Style x:Key="LegalityBadgeLabelPassStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeBold" />
        <Setter Property="FontSize" Value="{StaticResource Text2xs}" />
        <Setter Property="TextColor" Value="{StaticResource StatusPassFg}" />
        <Setter Property="CharacterSpacing" Value="0.6" />
    </Style>
    <Style x:Key="LegalityBadgeLabelFailStyle" TargetType="Label" BasedOn="{StaticResource LegalityBadgeLabelPassStyle}">
        <Setter Property="TextColor" Value="{StaticResource StatusFailFg}" />
    </Style>
    <Style x:Key="LegalityBannerPassStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusPassBg}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="LegalityBannerFailStyle" TargetType="Border" BasedOn="{StaticResource LegalityBannerPassStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusFailBg}" />
    </Style>
    <Style x:Key="LegalityMessagePassStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource StatusPassFg}" />
        <Setter Property="LineHeight" Value="{StaticResource LhNormal}" />
    </Style>
    <Style x:Key="LegalityMessageFailStyle" TargetType="Label" BasedOn="{StaticResource LegalityMessagePassStyle}">
        <Setter Property="TextColor" Value="{StaticResource StatusFailFg}" />
    </Style>

    <!-- Per-move legality dot: same pass/fail colour language as LegalityBadge above, but a small
         fixed-size circle rather than a pill, so it sits as a third column next to each move's type
         chip + Picker without competing for width. Sourced from LegalityAnalysis.Info.Moves[i] -
         see PokemonDetailPage.RefreshLegality - not a separate re-implementation of legality. -->
    <Style x:Key="MoveLegalityDotPassStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusPassBg}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="WidthRequest" Value="28" />
        <Setter Property="HeightRequest" Value="28" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="999" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="MoveLegalityDotFailStyle" TargetType="Border" BasedOn="{StaticResource MoveLegalityDotPassStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource StatusFailBg}" />
    </Style>
    <Style x:Key="MoveLegalityDotLabelPassStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeBold" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource StatusPassFg}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>
    <Style x:Key="MoveLegalityDotLabelFailStyle" TargetType="Label" BasedOn="{StaticResource MoveLegalityDotLabelPassStyle}">
        <Setter Property="TextColor" Value="{StaticResource StatusFailFg}" />
    </Style>
    <!-- Only ever shown for an invalid move (see RefreshLegality) - no Pass variant needed. -->
    <Style x:Key="MoveLegalityCaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource Text2xs}" />
        <Setter Property="TextColor" Value="{StaticResource StatusFailFg}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- TypeBadge (components/indicators/TypeBadge.jsx), in the "solid" variant and at the fixed
         width the bundle's own MoveRow uses it at (ui_kits/pkhexmobile/DetailScreen.jsx: solid,
         size="sm", fixed-width, centred, leading the move name) so the four move rows align in a
         column. Only the invariant geometry/typography lives here; the per-type fill is one of the
         18 Type* colour tokens and is applied in code-behind, since a Style per type would be 18
         near-identical copies. Width is 78, not the mockup's 62 - same intent (column alignment),
         but 62 truncates the longest type names ("FIGHTING"/"ELECTRIC") at this font size in MAUI,
         where the browser mockup could shrink to fit. -->
    <Style x:Key="TypeChipBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="WidthRequest" Value="78" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="999" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="TypeChipLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeBold" />
        <Setter Property="FontSize" Value="{StaticResource Text2xs}" />
        <Setter Property="CharacterSpacing" Value="0.6" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="MonoValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JetBrainsMonoSemiBold" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MonoMutedStyle" TargetType="Label" BasedOn="{StaticResource MonoValueStyle}">
        <Setter Property="FontFamily" Value="JetBrainsMonoMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiary}" />
    </Style>

    <Style x:Key="WarningBannerStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextSm}" />
        <Setter Property="TextColor" Value="{StaticResource StatusWarnFg}" />
        <Setter Property="LineHeight" Value="{StaticResource LhNormal}" />
    </Style>

    <!-- ===== Base control styles ===== -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchMin}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ManropeMedium" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchMin}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="TitleColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Accent}" />
        <Setter Property="ThumbColor" Value="{StaticResource Slate0}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{StaticResource Slate200}" />
                            <Setter Property="ThumbColor" Value="{StaticResource Slate200}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{StaticResource Slate0}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BorderSubtle}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- "Card" surface (SectionHeader + Card component from the design system) -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="Stroke" Value="{StaticResource BorderSubtle}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Party/box list row -->
    <Style x:Key="RowBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Box/party move grid cell (BoxListPage) - a square-ish tile for a single slot, empty or
         populated. Selection highlight is applied via a DataTrigger on IsSelected, not a second
         style, so a bound record's selection state can change without swapping styles. -->
    <Style x:Key="SlotCellStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSunken}" />
        <Setter Property="Stroke" Value="{StaticResource BorderSubtle}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource BorderSubtle}" />
    </Style>

    <!-- ===== Buttons (controls/Button.jsx: 4 variants x 4 states) ===== -->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="ManropeSemiBold" />
        <Setter Property="FontSize" Value="{StaticResource TextBase}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
        <Setter Property="Behaviors">
            <Setter.Value>
                <local:PressScaleBehavior />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Shadow" Value="{StaticResource ShadowXs}" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource TextOnAccent}" />
        <Setter Property="BackgroundColor" Value="{StaticResource AccentActive}" />
        <Setter Property="Shadow" Value="{StaticResource ShadowXs}" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor" Value="{StaticResource BorderDefault}" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <!-- Default (unkeyed) Button style = primary, so any un-styled Button still matches the system -->
    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />

    <!-- ===== Page / Shell chrome ===== -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource BgApp}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource Slate300}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextTertiary}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource TextPrimary}" />
    </Style>

</ResourceDictionary>
