<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ================================================================
         PkhexMobile design tokens — ported from
         "PkhexMobile Design System/design_handoff_pkhexmobile/tokens/colors.css"
         and "tokens/type-colors.css". Values are final per the design
         handoff (high-fidelity); this file is a 1:1 token port, not a
         reinterpretation.
         ================================================================ -->

    <!-- ===== Base neutrals — cool slate ===== -->
    <Color x:Key="Slate0">#FFFFFF</Color>
    <Color x:Key="Slate50">#F6F8FB</Color>
    <Color x:Key="Slate100">#EDF1F6</Color>
    <Color x:Key="Slate200">#DEE4EC</Color>
    <Color x:Key="Slate300">#C6CFDB</Color>
    <Color x:Key="Slate400">#98A3B3</Color>
    <Color x:Key="Slate500">#6B7686</Color>
    <Color x:Key="Slate600">#4C5666</Color>
    <Color x:Key="Slate700">#353E4C</Color>
    <Color x:Key="Slate800">#212834</Color>
    <Color x:Key="Slate900">#141A23</Color>
    <Color x:Key="Slate950">#0B0F16</Color>

    <!-- ===== Brand — refined poké red ===== -->
    <Color x:Key="Red50">#FFF1F1</Color>
    <Color x:Key="Red100">#FFE0E1</Color>
    <Color x:Key="Red200">#FFC7C9</Color>
    <Color x:Key="Red300">#F79FA2</Color>
    <Color x:Key="Red400">#F06D72</Color>
    <Color x:Key="Red500">#E5484D</Color>
    <Color x:Key="Red600">#D02D33</Color>
    <Color x:Key="Red700">#AE2126</Color>
    <Color x:Key="Red800">#8B1B1F</Color>

    <!-- ===== Semantic hues ===== -->
    <Color x:Key="Green100">#D6F5E6</Color>
    <Color x:Key="Green500">#16A46B</Color>
    <Color x:Key="Green600">#0E8556</Color>
    <Color x:Key="Amber100">#FCEFCB</Color>
    <Color x:Key="Amber500">#E7960B</Color>
    <Color x:Key="Amber600">#C07C05</Color>
    <Color x:Key="Blue100">#DBEAFE</Color>
    <Color x:Key="Blue500">#3B7DED</Color>
    <Color x:Key="Blue600">#2A63C4</Color>
    <Color x:Key="Gold100">#FBEFC5</Color>
    <Color x:Key="Gold400">#F2C24B</Color>
    <Color x:Key="Gold500">#E7A812</Color>

    <!-- ===== Semantic aliases (light) ===== -->
    <Color x:Key="BgApp">#F6F8FB</Color>
    <Color x:Key="BgAppElevated">#EDF1F6</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="SurfaceRaised">#FFFFFF</Color>
    <Color x:Key="SurfaceSunken">#EDF1F6</Color>
    <Color x:Key="SurfaceInset">#F6F8FB</Color>

    <Color x:Key="BorderSubtle">#DEE4EC</Color>
    <Color x:Key="BorderDefault">#C6CFDB</Color>
    <Color x:Key="BorderStrong">#98A3B3</Color>

    <Color x:Key="TextPrimary">#141A23</Color>
    <Color x:Key="TextSecondary">#4C5666</Color>
    <Color x:Key="TextTertiary">#6B7686</Color>
    <Color x:Key="TextDisabled">#98A3B3</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>

    <Color x:Key="Accent">#E5484D</Color>
    <Color x:Key="AccentHover">#D02D33</Color>
    <Color x:Key="AccentActive">#AE2126</Color>
    <Color x:Key="AccentSoft">#FFF1F1</Color>
    <Color x:Key="AccentSoftBorder">#FFC7C9</Color>

    <!-- red-500 @ 45% alpha (source: color-mix(in oklch, red-500 45%, transparent)) -->
    <Color x:Key="FocusRing">#73E5484D</Color>

    <!-- ===== Status ===== -->
    <Color x:Key="StatusPassFg">#0E8556</Color>
    <Color x:Key="StatusPassBg">#D6F5E6</Color>
    <Color x:Key="StatusWarnFg">#C07C05</Color>
    <Color x:Key="StatusWarnBg">#FCEFCB</Color>
    <Color x:Key="StatusFailFg">#AE2126</Color>
    <Color x:Key="StatusFailBg">#FFE0E1</Color>
    <Color x:Key="StatusInfoFg">#2A63C4</Color>
    <Color x:Key="StatusInfoBg">#DBEAFE</Color>

    <!-- ===== Shiny ===== -->
    <Color x:Key="ShinyFg">#E7A812</Color>
    <Color x:Key="ShinyBg">#FBEFC5</Color>

    <!-- ===== Stat accent (HP/Atk/Def/SpA/SpD/Spe) ===== -->
    <Color x:Key="StatHp">#EB5A54</Color>
    <Color x:Key="StatAtk">#F0913E</Color>
    <Color x:Key="StatDef">#F2C94C</Color>
    <Color x:Key="StatSpa">#62A9F5</Color>
    <Color x:Key="StatSpd">#58C48A</Color>
    <Color x:Key="StatSpe">#E06BC9</Color>
    <Color x:Key="StatTrack">#DEE4EC</Color>

    <!-- ===== Pokémon type palette (18 muted hues + soft bg) ===== -->
    <Color x:Key="TypeNormal">#9AA0A9</Color>
    <Color x:Key="TypeNormalBg">#EEEFF1</Color>
    <Color x:Key="TypeFire">#EE7B45</Color>
    <Color x:Key="TypeFireBg">#FCEBE0</Color>
    <Color x:Key="TypeWater">#4E90DA</Color>
    <Color x:Key="TypeWaterBg">#E3EDF9</Color>
    <Color x:Key="TypeElectric">#E8B32B</Color>
    <Color x:Key="TypeElectricBg">#FBF1D2</Color>
    <Color x:Key="TypeGrass">#5BB463</Color>
    <Color x:Key="TypeGrassBg">#E2F1E3</Color>
    <Color x:Key="TypeIce">#6FC7C4</Color>
    <Color x:Key="TypeIceBg">#E1F3F2</Color>
    <Color x:Key="TypeFighting">#C0403C</Color>
    <Color x:Key="TypeFightingBg">#F6E0DF</Color>
    <Color x:Key="TypePoison">#9A5CB4</Color>
    <Color x:Key="TypePoisonBg">#EFE4F4</Color>
    <Color x:Key="TypeGround">#C9924A</Color>
    <Color x:Key="TypeGroundBg">#F5EBDC</Color>
    <Color x:Key="TypeFlying">#8C9BE0</Color>
    <Color x:Key="TypeFlyingBg">#E9ECF9</Color>
    <Color x:Key="TypePsychic">#E56E93</Color>
    <Color x:Key="TypePsychicBg">#FBE5EC</Color>
    <Color x:Key="TypeBug">#9DB03C</Color>
    <Color x:Key="TypeBugBg">#EEF1DC</Color>
    <Color x:Key="TypeRock">#B4A265</Color>
    <Color x:Key="TypeRockBg">#F1EDDE</Color>
    <Color x:Key="TypeGhost">#6A5896</Color>
    <Color x:Key="TypeGhostBg">#E5E1EF</Color>
    <Color x:Key="TypeDragon">#6247C4</Color>
    <Color x:Key="TypeDragonBg">#E3DEF6</Color>
    <Color x:Key="TypeDark">#59535F</Color>
    <Color x:Key="TypeDarkBg">#E6E4E9</Color>
    <Color x:Key="TypeSteel">#6E93A6</Color>
    <Color x:Key="TypeSteelBg">#E6EDF1</Color>
    <Color x:Key="TypeFairy">#E58BC7</Color>
    <Color x:Key="TypeFairyBg">#FBE7F4</Color>

    <!-- ===== Brushes for properties that require a Brush, not a Color ===== -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCard}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />

</ResourceDictionary>
