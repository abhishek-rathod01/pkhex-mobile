<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.BoxListPage"
             x:DataType="local:BoxListPage"
             Title="Boxes">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">
        <Label Grid.Row="0" Text="Boxes" Style="{StaticResource ScreenTitleStyle}" Margin="0,4,0,10" />

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12">
            <VerticalStackLayout Spacing="6">
                <Label Text="Box" Style="{StaticResource LabelCaptionStyle}" />
                <Picker x:Name="BoxPicker"
                        Title="Select box"
                        SelectedIndexChanged="OnBoxSelected" />
                <Label x:Name="HeaderLabel" Style="{StaticResource MutedStyle}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView x:Name="BoxList"
                         Grid.Row="2"
                         SelectionMode="Single"
                         SelectionChanged="OnBoxEntrySelected">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:PartyEntryDisplay">
                    <Border Style="{StaticResource RowBorderStyle}">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" WidthRequest="52" HeightRequest="52"
                                    Stroke="Transparent" StrokeThickness="0"
                                    BackgroundColor="{StaticResource SurfaceSunken}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid>
                                    <Image Source="sprite_placeholder.svg" Aspect="AspectFit"
                                           WidthRequest="26" HeightRequest="26"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Image Source="{Binding SpriteFile}" Aspect="AspectFit"
                                           WidthRequest="44" HeightRequest="44"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding Nickname}" Style="{StaticResource RowTitleStyle}" />
                                    <Label Text="&#9733;" Style="{StaticResource ShinyStarStyle}" IsVisible="{Binding IsShiny}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding SpeciesName}" Style="{StaticResource MutedStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="End" VerticalOptions="Center">
                                <Label Text="{Binding Level, StringFormat='Lv {0}'}" Style="{StaticResource MonoValueStyle}"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding ItemFirstWord}" Style="{StaticResource MonoMutedStyle}"
                                       IsVisible="{Binding HasItem}" HorizontalTextAlignment="End" />
                                <Label Text="No item" Style="{StaticResource MonoMutedStyle}"
                                       IsVisible="{Binding HasNoItem}"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
