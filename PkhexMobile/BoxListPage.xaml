<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.BoxListPage"
             x:DataType="local:BoxListPage"
             Title="Boxes">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20">
        <Picker x:Name="BoxPicker"
                Grid.Row="0"
                Title="Box"
                SelectedIndexChanged="OnBoxSelected"
                Margin="0,0,0,10" />

        <Label x:Name="HeaderLabel"
               Grid.Row="1"
               FontSize="16"
               Margin="0,0,0,10" />

        <CollectionView x:Name="BoxList"
                         Grid.Row="2"
                         SelectionMode="Single"
                         SelectionChanged="OnBoxEntrySelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:PartyEntryDisplay">
                    <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="{Binding Slot}" FontAttributes="Bold" WidthRequest="30" />
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="{Binding Nickname}" FontAttributes="Bold" />
                            <Label Text="{Binding SpeciesName}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding Level, StringFormat='Lv. {0}'}" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
