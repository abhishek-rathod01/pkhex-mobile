<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.PokemonDetailPage"
             Title="Details">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Hero -->
            <Grid ColumnDefinitions="88,*" ColumnSpacing="16" Margin="0,4,0,0">
                <Border WidthRequest="88" HeightRequest="88" Stroke="Transparent" StrokeThickness="0"
                        BackgroundColor="{StaticResource SurfaceSunken}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid>
                        <Image Source="sprite_placeholder.svg" Aspect="AspectFit"
                               WidthRequest="44" HeightRequest="44"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Image x:Name="SpriteImage" Aspect="AspectFit"
                               WidthRequest="76" HeightRequest="76"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="TitleLabel" Style="{StaticResource HeroTitleStyle}" />
                        <Label x:Name="ShinyStarLabel" Text="&#9733;" Style="{StaticResource ShinyStarStyle}" IsVisible="False" />
                    </HorizontalStackLayout>
                    <Label x:Name="SubtitleLabel" Style="{StaticResource MutedStyle}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Legality result banner: read-only PKHeX.Core LegalityAnalysis snapshot, recomputed on
                 load and after a successful save. No auto-fix - this only reports. -->
            <Border x:Name="LegalityBanner">
                <VerticalStackLayout Spacing="8">
                    <Border x:Name="LegalityBadgeBorder">
                        <Label x:Name="LegalityBadgeLabel" />
                    </Border>
                    <Label x:Name="LegalityMessageLabel" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Legality warning banner (always visible - no auto-fix/legality engine, see README) -->
            <Border BackgroundColor="{StaticResource StatusWarnBg}" Stroke="Transparent" StrokeThickness="0" Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label x:Name="LegalityWarningLabel"
                       Text="⚠ Species, form, ability, nature, and move edits are applied exactly as chosen. PKHeX.Core does not auto-fix legality, so the result may be flagged as illegal by other tools. This is expected."
                       Style="{StaticResource WarningBannerStyle}"
                       LineBreakMode="WordWrap" />
            </Border>

            <!-- Main -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Main" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="Nickname" Style="{StaticResource LabelCaptionStyle}" />
                    <Entry x:Name="NicknameEntry" />

                    <Label Text="Level" Style="{StaticResource LabelCaptionStyle}" />
                    <Entry x:Name="LevelEntry" Keyboard="Numeric" />

                    <Label Text="Species" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="SpeciesPicker" Title="Select species" />

                    <!-- Form: only enabled Gen4+ (independently stored - see PROGRESS.md) and when
                         the current species actually has more than one form. Gen1-3's Form setter
                         only ever does anything for Unown (via IV/PID randomization side effects) -
                         deliberately not wired up here (too surprising to expose as a plain picker),
                         so it's disabled there too. Always shown (not hidden) so the current value is
                         still visible, matching the Gen1/2 IV field disabling precedent. -->
                    <Label x:Name="FormCaptionLabel" Text="Form" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="FormPicker" Title="Select form" />

                    <Label Text="Held item" Style="{StaticResource LabelCaptionStyle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Border x:Name="ItemIconBorder" WidthRequest="28" HeightRequest="28"
                                Stroke="Transparent" StrokeThickness="0"
                                BackgroundColor="{StaticResource SurfaceSunken}" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Image x:Name="ItemSpriteImage" Aspect="AspectFit" WidthRequest="20" HeightRequest="20" />
                        </Border>
                        <Label x:Name="ItemNameLabel" Style="{StaticResource BodyStyle}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Moves -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Moves" Style="{StaticResource SectionTitleStyle}" />
                    <Picker x:Name="Move1Picker" Title="Move 1" />
                    <Picker x:Name="Move2Picker" Title="Move 2" />
                    <Picker x:Name="Move3Picker" Title="Move 3" />
                    <Picker x:Name="Move4Picker" Title="Move 4" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Stats" Style="{StaticResource SectionTitleStyle}" />

                    <!-- Ability: only enabled Gen4+ (independently stored, real setter - see
                         PROGRESS.md). Gen1/2 has no Ability concept at all (sentinel -1); Gen3's
                         Ability is real and meaningful to *display* (derived from the ability slot)
                         but its direct-by-ID setter is a no-op - both stay disabled, but still show
                         the correct current value rather than a misleading one. -->
                    <Label x:Name="AbilityCaptionLabel" Text="Ability" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="AbilityPicker" Title="Select ability" />

                    <!-- Nature: only enabled Gen5+ (independently stored, real setter - see
                         PROGRESS.md). Gen3/4's Nature is real and meaningful to *display* (PID % 25)
                         but its setter is a no-op absent a PID-rerolling workaround this app
                         deliberately doesn't use (PKHeX.Core's own SetPIDNature also de-shinies the
                         mon as a side effect - too surprising for a plain picker). Gen1/2 has no
                         Nature concept at all (sentinel Hardy/0). -->
                    <Label x:Name="NatureCaptionLabel" Text="Nature" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="NaturePicker" Title="Select nature" />

                    <Label x:Name="IvRangeLabel" Text="IVs (0-31 each)" Style="{StaticResource LabelCaptionStyle}" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <Entry x:Name="IvHpEntry" Grid.Column="0" Keyboard="Numeric" Placeholder="HP" />
                        <Entry x:Name="IvAtkEntry" Grid.Column="1" Keyboard="Numeric" Placeholder="Atk" />
                        <Entry x:Name="IvDefEntry" Grid.Column="2" Keyboard="Numeric" Placeholder="Def" />
                        <Entry x:Name="IvSpaEntry" Grid.Column="3" Keyboard="Numeric" Placeholder="SpA" />
                        <Entry x:Name="IvSpdEntry" Grid.Column="4" Keyboard="Numeric" Placeholder="SpD" />
                        <Entry x:Name="IvSpeEntry" Grid.Column="5" Keyboard="Numeric" Placeholder="Spe" />
                    </Grid>

                    <Label x:Name="EvRangeLabel" Text="EVs (0-252 each)" Style="{StaticResource LabelCaptionStyle}" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <Entry x:Name="EvHpEntry" Grid.Column="0" Keyboard="Numeric" Placeholder="HP" />
                        <Entry x:Name="EvAtkEntry" Grid.Column="1" Keyboard="Numeric" Placeholder="Atk" />
                        <Entry x:Name="EvDefEntry" Grid.Column="2" Keyboard="Numeric" Placeholder="Def" />
                        <Entry x:Name="EvSpaEntry" Grid.Column="3" Keyboard="Numeric" Placeholder="SpA" />
                        <Entry x:Name="EvSpdEntry" Grid.Column="4" Keyboard="Numeric" Placeholder="SpD" />
                        <Entry x:Name="EvSpeEntry" Grid.Column="5" Keyboard="Numeric" Placeholder="Spe" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="SaveChangesBtn"
                    Text="Save Changes"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="OnSaveChangesClicked"
                    HorizontalOptions="Fill"
                    IsEnabled="False" />

            <Label x:Name="SaveStatusLabel" Style="{StaticResource MutedStyle}" LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
