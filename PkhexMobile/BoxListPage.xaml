<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.BoxListPage"
             x:DataType="local:BoxListPage"
             Title="Boxes">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="12">
        <Label Grid.Row="0" Text="Boxes" Style="{StaticResource ScreenTitleStyle}" Margin="0,4,0,0" />

        <!-- Move mode: OFF (default) preserves the pre-existing read-only browse behavior exactly
             (tap a slot -> open the detail screen). ON repurposes tap for the select-then-tap-
             destination move fallback, so the two gestures never collide. Drag-and-drop (below) is
             always active regardless of this switch - it's a distinct gesture from a plain tap. -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12">
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout Spacing="10">
                    <Switch x:Name="MoveModeSwitch" Toggled="OnMoveModeToggled" />
                    <Label Text="Move mode (drag or tap-to-select a Pokemon, then tap its destination)"
                           Style="{StaticResource BodySecondaryStyle}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Label x:Name="StatusLabel" Style="{StaticResource MutedStyle}" />
                <Button x:Name="ExportBtn" Text="Export Save" Style="{StaticResource SecondaryButtonStyle}"
                        Clicked="OnExportClicked" IsEnabled="False" HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Border>

        <!-- Party: always visible so party<->box and party<->party moves have both ends on screen
             at once. Shows every populated slot plus exactly one trailing empty "append" cell -
             see BuildPartyCells for why only one. -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="12">
            <VerticalStackLayout Spacing="8">
                <Label x:Name="PartyHeaderLabel" Text="Party" Style="{StaticResource SectionTitleStyle}" />
                <CollectionView x:Name="PartyGrid" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="6" HorizontalItemSpacing="6" VerticalItemSpacing="6" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:SlotCellDisplay">
                            <Border Style="{StaticResource SlotCellStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCellTapped" />
                                    <DragGestureRecognizer CanDrag="True" DragStarting="OnCellDragStarting" />
                                    <DropGestureRecognizer Drop="OnCellDrop" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                        <Setter Property="BackgroundColor" Value="{StaticResource AccentSoft}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid RowDefinitions="Auto,Auto" VerticalOptions="Center">
                                    <Image Grid.Row="0" Source="{Binding SpriteFile}" Aspect="AspectFit"
                                           WidthRequest="34" HeightRequest="34" IsVisible="{Binding HasSprite}"
                                           HorizontalOptions="Center" />
                                    <Label Grid.Row="0" Text="{Binding SlotNumberText}" IsVisible="{Binding IsEmpty}"
                                           Style="{StaticResource MonoMutedStyle}" HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Text="{Binding LevelText}" Style="{StaticResource MonoMutedStyle}"
                                           FontSize="{StaticResource Text2xs}" HorizontalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- Box: picker + scrollable grid, all slots rendered (including empty ones - boxes are
             already allowed to have holes, unlike party). -->
        <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="12">
            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Box" Style="{StaticResource LabelCaptionStyle}" />
                    <Picker x:Name="BoxPicker"
                            Title="Select box"
                            SelectedIndexChanged="OnBoxSelected" />
                    <Label x:Name="BoxHeaderLabel" Style="{StaticResource MutedStyle}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView x:Name="BoxGrid" Grid.Row="1" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="5" HorizontalItemSpacing="6" VerticalItemSpacing="6" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:SlotCellDisplay">
                        <Border Style="{StaticResource SlotCellStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCellTapped" />
                                <DragGestureRecognizer CanDrag="True" DragStarting="OnCellDragStarting" />
                                <DropGestureRecognizer Drop="OnCellDrop" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource AccentSoft}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid RowDefinitions="Auto,Auto" VerticalOptions="Center">
                                <Image Grid.Row="0" Source="{Binding SpriteFile}" Aspect="AspectFit"
                                       WidthRequest="30" HeightRequest="30" IsVisible="{Binding HasSprite}"
                                       HorizontalOptions="Center" />
                                <Label Grid.Row="0" Text="{Binding SlotNumberText}" IsVisible="{Binding IsEmpty}"
                                       Style="{StaticResource MonoMutedStyle}" FontSize="{StaticResource Text2xs}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Label Grid.Row="1" Text="{Binding LevelText}" Style="{StaticResource MonoMutedStyle}"
                                       FontSize="{StaticResource Text2xs}" HorizontalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>

</ContentPage>
