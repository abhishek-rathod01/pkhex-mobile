<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PkhexMobile"
             x:Class="PkhexMobile.PokedexDetailPage"
             x:DataType="local:PokedexDetailPage">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Hero -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Image x:Name="SpriteImage" Aspect="AspectFit" WidthRequest="96" HeightRequest="96" />
                    <Label x:Name="DexNumberLabel" Style="{StaticResource MonoMutedStyle}" HorizontalOptions="Center" />
                    <Label x:Name="NameLabel" Style="{StaticResource HeroTitleStyle}" HorizontalOptions="Center" />
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border x:Name="Type1Chip" Padding="10,4" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{StaticResource RadiusPill}" />
                            </Border.StrokeShape>
                            <Label x:Name="Type1Label" FontFamily="ManropeBold" FontSize="{StaticResource TextXs}" />
                        </Border>
                        <Border x:Name="Type2Chip" Padding="10,4" StrokeThickness="0" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{StaticResource RadiusPill}" />
                            </Border.StrokeShape>
                            <Label x:Name="Type2Label" FontFamily="ManropeBold" FontSize="{StaticResource TextXs}" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Abilities -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Abilities" Style="{StaticResource SectionTitleStyle}" />
                    <VerticalStackLayout x:Name="AbilitiesList" Spacing="4">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Label Text="{Binding .}" Style="{StaticResource BodyStyle}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Base stats -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Base Stats" Style="{StaticResource SectionTitleStyle}" />

                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8" RowDefinitions="Auto">
                        <Label Grid.Column="0" Text="HP" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="HpBar" Grid.Column="1" ProgressColor="{StaticResource StatHp}" VerticalOptions="Center" />
                        <Label x:Name="HpValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>
                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Attack" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="AtkBar" Grid.Column="1" ProgressColor="{StaticResource StatAtk}" VerticalOptions="Center" />
                        <Label x:Name="AtkValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>
                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Defense" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="DefBar" Grid.Column="1" ProgressColor="{StaticResource StatDef}" VerticalOptions="Center" />
                        <Label x:Name="DefValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>
                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Sp. Atk" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="SpaBar" Grid.Column="1" ProgressColor="{StaticResource StatSpa}" VerticalOptions="Center" />
                        <Label x:Name="SpaValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>
                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Sp. Def" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="SpdBar" Grid.Column="1" ProgressColor="{StaticResource StatSpd}" VerticalOptions="Center" />
                        <Label x:Name="SpdValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>
                    <Grid ColumnDefinitions="70,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Speed" Style="{StaticResource LabelCaptionStyle}" VerticalOptions="Center" />
                        <ProgressBar x:Name="SpeBar" Grid.Column="1" ProgressColor="{StaticResource StatSpe}" VerticalOptions="Center" />
                        <Label x:Name="SpeValueLabel" Grid.Column="2" Style="{StaticResource MonoValueStyle}" HorizontalTextAlignment="End" />
                    </Grid>

                    <Label x:Name="TotalStatLabel" Style="{StaticResource MutedStyle}" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Forms (regional / Mega / Gmax) -->
            <Border x:Name="FormsCard" Style="{StaticResource CardBorderStyle}" IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Forms" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="Battle-only forms (Mega/Gigantamax) and regional forms are both sourced from PKHeX.Core's own form-name data - not separately verified per species."
                           Style="{StaticResource MutedStyle}" />
                    <VerticalStackLayout x:Name="FormsList" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="local:FormEntryDisplay">
                                <VerticalStackLayout Spacing="1">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyStyle}" />
                                    <Label Text="{Binding Note}" IsVisible="{Binding HasNote}"
                                           Style="{StaticResource MutedStyle}" FontSize="{StaticResource Text2xs}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Evolution chain -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Evolution Chain" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="Source: PKHeX.Core evolution data (Scarlet/Violet tree)" Style="{StaticResource MutedStyle}" FontSize="{StaticResource Text2xs}" />
                    <Label x:Name="EvolutionSingleLabel" Text="This species does not evolve and has no pre-evolution." Style="{StaticResource MutedStyle}" IsVisible="False" />
                    <VerticalStackLayout x:Name="EvolutionList" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="local:EvoNodeDisplay">
                                <Grid Margin="{Binding IndentMargin}" ColumnDefinitions="40,*" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                                    <Image Grid.Column="0" Grid.RowSpan="2" Source="{Binding SpriteFile}"
                                           Aspect="AspectFit" WidthRequest="36" HeightRequest="36" />
                                    <Label Grid.Column="1" Grid.Row="0" Text="{Binding Name}" Style="{StaticResource RowTitleStyle}" />
                                    <HorizontalStackLayout Grid.Column="1" Grid.Row="1" Spacing="6" IsVisible="{Binding HasMethod}">
                                        <Image Source="{Binding ItemSpriteFile}" IsVisible="{Binding HasItem}"
                                               WidthRequest="18" HeightRequest="18" Aspect="AspectFit" />
                                        <Label Text="{Binding MethodText}" Style="{StaticResource MutedStyle}" FontSize="{StaticResource TextXs}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
