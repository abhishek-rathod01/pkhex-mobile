<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             x:Class="PkhexMobile.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <VerticalStackLayout Spacing="8" Margin="0,24,0,4" HorizontalOptions="Center">
                <Image Source="pokeball_mark.svg" HeightRequest="64" WidthRequest="64" Aspect="AspectFit" />
                <Label Text="PkhexMobile" Style="{StaticResource ScreenTitleStyle}" HorizontalTextAlignment="Center" />
                <Label Text="PKHeX.Core save editor" Style="{StaticResource MutedStyle}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Load a save file" Style="{StaticResource SectionTitleStyle}" />

                    <Button
                        x:Name="PickFileBtn"
                        Text="Pick a file"
                        Style="{StaticResource SecondaryButtonStyle}"
                        SemanticProperties.Hint="Opens the file picker and reads the selected file"
                        Clicked="OnPickFileClicked"
                        HorizontalOptions="Fill" />

                    <Label
                        x:Name="FileResultLabel"
                        Text=""
                        Style="{StaticResource MutedStyle}"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Button
                x:Name="ViewPartyBtn"
                Text="View Party"
                Style="{StaticResource PrimaryButtonStyle}"
                IsVisible="False"
                Clicked="OnViewPartyClicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="ViewBoxesBtn"
                Text="View Boxes"
                Style="{StaticResource SecondaryButtonStyle}"
                IsVisible="False"
                Clicked="OnViewBoxesClicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="ViewTrainerBtn"
                Text="View Trainer"
                Style="{StaticResource SecondaryButtonStyle}"
                IsVisible="False"
                Clicked="OnViewTrainerClicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="ViewPokedexBtn"
                Text="Pokedex"
                Style="{StaticResource GhostButtonStyle}"
                Clicked="OnViewPokedexClicked"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
